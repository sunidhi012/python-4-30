# Dynamic CSV Header mapper 
student_data = {
    'ID' : 101, 
    'Name': 'Sita',
    'Grade': 'A'
}


with open('student.csv','w',newline='') as file:
    writer = csv.DictWriter(file, fieldnames=student_data.keys()) # create csv file
    writer.writeheader()
    writer.writerow(student_data) #write data in csv file


with open ('student.csv', 'r') as file:
    reader = csv.DictReader(file)
    for row in reader:
        for idx, val in row.items():
            print(f'{idx} : {val}')
        


#extract keys from dictionary
fieldnames = student_data.keys()

with open("student.csv", "w", newline="") as file:
    writer = csv.DictWriter(file, fieldnames=fieldnames)

    writer.writeheader()
    writer.writerow(student_data)

print("CSV file created successfully.")


#save the data into students.csv 
fieldnames = student_data.keys()

with open("students.csv", "w", newline="") as file:
    writer = csv.DictWriter(file, fieldnames=fieldnames)

    writer.writeheader()
    writer.writerow(student_data)

print("Data saved to students.csv successfully.")


 
